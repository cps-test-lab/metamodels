      "BagFileMetadata": "robovast:BagFile#Metadata",

      "TestResult": "robovast:TestResult",
      "LogFile": "robovast:LogFile",

      "Postprocessing": "robovast:Postprocessing",
      "plugin": {
        "@id": "robovast:plugin",
        "@type": "xsd:string"
      },
      "Plugin": "robovast:Plugin",
      "frames": {
        "@id": "robovast:frames",
        "@type": "xsd:string"
      },

      "Traces": "robovast:Traces",
