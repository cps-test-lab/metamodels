      "n_obstacles": {
        "@id": "scenarios:n_obstacles",
        "@type": "xsd:integer"
      },

      "TestExecution": "robovast:TestExecution",
      "sysinfo": {
        "@id": "robovast:sysinfo",
        "@type": "@id"
      },
      "success": {
        "@id": "robovast:TestResult#success",
        "@type": "xsd:boolean"
      },

      "RosBag": "robovast:RosBag",

      "MCAPFile": "robovast:MCAPFile",
      "message_types": {
        "@id": "robovast:ros/message_types/",
        "@type": "@id"
